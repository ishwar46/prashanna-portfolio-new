# Site URL (used for SEO metadata, sitemap, and OG image)
NEXT_PUBLIC_SITE_URL=https://


# Gmail SMTP Configuration for Contact Form
# 1. Enable 2FA on your Google Account: myaccount.google.com -> Security -> 2-Step Verification
# 2. Generate App Password: myaccount.google.com -> Security -> App Passwords -> select "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_USER=
SMTP_PASS=
